---
import { Github, ListTree, Menu } from 'lucide-astro';
import SiteSearch from './SiteSearch.astro';
import SunMoonToggle from './SunMoonToggle.astro';
import { getSiteConfig } from '../../data/site';

interface Props {
  showTocIcon?: boolean;
  tocItems?: { href: string; label: string }[];
}

const { showTocIcon = false, tocItems = [] } = Astro.props;
const { site, topNav, search } = await getSiteConfig();
const links = topNav.links;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPathname =
  basePath && Astro.url.pathname.startsWith(basePath)
    ? Astro.url.pathname.slice(basePath.length) || '/'
    : Astro.url.pathname;
const currentPath = currentPathname.replace(/\/$/, '') || '/';

function withBase(href: string) {
  if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('#')) {
    return href;
  }

  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}

function isActive(href: string) {
  if (href.startsWith('http')) return false;

  const normalizedHref = href.replace(/\/$/, '') || '/';

  if (normalizedHref === '/') {
    return currentPath === '/';
  }

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}

const routeLabels: Record<string, string> = {
  '/blog': 'blog',
  '/projects': 'projects',
  '/vibe': 'vibe',
  '/archive': 'archive',
  '/about': 'about',
};
const activeRoute = Object.entries(routeLabels).find(
  ([route]) => currentPath === route || currentPath.startsWith(`${route}/`),
);
const brandRouteLabel = activeRoute?.[1];
const shouldShowTocAction = showTocIcon && tocItems.length > 0;
---

<header class="blog-top-nav" data-pagefind-ignore>
  <span class="nav-liquid-glass" aria-hidden="true" data-liquid-glass-layer></span>

  <button
    class="mobile-menu-toggle"
    type="button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="mobile-nav-menu"
    data-mobile-menu-toggle
  >
    <Menu size={18} stroke-width={2} />
  </button>

  <a class="brand" href={withBase('/')} aria-label={`Go to ${site.title} home`}>
    <span class="brand-mark" aria-hidden="true"></span>
    <span class="brand-title">
      <span>{site.title}</span>
      {brandRouteLabel && <span class="brand-route"> · {brandRouteLabel}</span>}
    </span>
  </a>

  <nav class="nav-links" aria-label="Article navigation">
    {
      links.map((link) =>
        link.disabled ? (
          <span
            class="nav-link nav-link-placeholder"
            aria-disabled="true"
            title="Projects content placeholder"
          >
            {link.label}
          </span>
        ) : (
          <a class:list={['nav-link', { active: isActive(link.href) }]} href={withBase(link.href)}>
            {link.label}
          </a>
        ),
      )
    }
  </nav>

  <nav
    class="mobile-menu-panel"
    id="mobile-nav-menu"
    aria-label="Mobile navigation"
    data-mobile-menu
  >
    {
      links.map((link) =>
        link.disabled ? (
          <span class="mobile-menu-link mobile-menu-placeholder" aria-disabled="true">
            {link.label}
          </span>
        ) : (
          <a
            class:list={['mobile-menu-link', { active: isActive(link.href) }]}
            href={withBase(link.href)}
            data-mobile-menu-link
          >
            {link.label}
          </a>
        ),
      )
    }
  </nav>

  <div class="nav-actions" aria-label="Page actions">
    <a
      href={site.repository}
      target="_blank"
      rel="noreferrer"
      aria-label="Open GitHub repository"
      title="GitHub"
    >
      <Github size={17} stroke-width={2} />
    </a>
    {search.enabled && <SiteSearch search={search} />}
    <SunMoonToggle />
    {
      shouldShowTocAction && (
        <button
          class="toc-action"
          type="button"
          aria-label="Open table of contents"
          aria-expanded="false"
          aria-controls="mobile-toc-menu"
          title="Table of contents"
          data-mobile-toc-trigger
        >
          <ListTree size={17} stroke-width={2} />
        </button>
      )
    }
  </div>

  {
    shouldShowTocAction && (
      <nav
        class="mobile-toc-panel"
        id="mobile-toc-menu"
        aria-label="Article table of contents"
        data-nav-toc-menu
        data-toc-root
      >
        <p>Table of contents</p>
        <ol>
          {tocItems.map((item, index) => (
            <li>
              <a href={item.href} data-nav-toc-link data-toc-link data-toc-hash={item.href}>
                <span>{index + 1}</span>
                {item.label}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )
  }
</header>

<script>
  const liquidGlassNavCleanups = new WeakMap<HTMLElement, () => void>();

  const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));

  const smoothStep = (edge0: number, edge1: number, value: number) => {
    const t = clamp((value - edge0) / (edge1 - edge0), 0, 1);
    return t * t * (3 - 2 * t);
  };

  const roundedRectSdf = (
    x: number,
    y: number,
    halfWidth: number,
    halfHeight: number,
    radius: number,
  ) => {
    const qx = Math.abs(x) - halfWidth + radius;
    const qy = Math.abs(y) - halfHeight + radius;
    return Math.min(Math.max(qx, qy), 0) + Math.hypot(Math.max(qx, 0), Math.max(qy, 0)) - radius;
  };

  const createLiquidGlassMap = (width: number, height: number, radius: number) => {
    const canvas = document.createElement('canvas');
    const pixelRatio = Math.min(window.devicePixelRatio || 1, 1.5);
    const canvasWidth = Math.max(1, Math.round(width * pixelRatio));
    const canvasHeight = Math.max(1, Math.round(height * pixelRatio));
    canvas.width = canvasWidth;
    canvas.height = canvasHeight;

    const context = canvas.getContext('2d');
    if (!context) {
      return '';
    }

    const imageData = context.createImageData(canvasWidth, canvasHeight);
    const data = imageData.data;
    const scaledRadius = radius * pixelRatio;
    const halfWidth = canvasWidth / 2;
    const halfHeight = canvasHeight / 2;
    const edgeWidth = Math.max(10, Math.min(canvasWidth, canvasHeight) * 0.32);
    const rippleWidth = Math.max(6, Math.min(canvasWidth, canvasHeight) * 0.13);

    for (let y = 0; y < canvasHeight; y += 1) {
      for (let x = 0; x < canvasWidth; x += 1) {
        const centeredX = x - halfWidth;
        const centeredY = y - halfHeight;
        const distance = roundedRectSdf(centeredX, centeredY, halfWidth, halfHeight, scaledRadius);
        const edge = 1 - smoothStep(0, edgeWidth, Math.abs(distance));
        const innerRipple = Math.sin((x / canvasWidth) * Math.PI * 2.5) * 0.15 + 0.85;
        const softBend = clamp(edge * innerRipple, 0, 1);
        const cornerGlow = smoothStep(rippleWidth, 0, Math.abs(distance));
        const normalX = centeredX / Math.max(1, halfWidth);
        const normalY = centeredY / Math.max(1, halfHeight);
        const index = (y * canvasWidth + x) * 4;

        data[index] = clamp(128 + normalX * softBend * 55 + cornerGlow * 9, 0, 255);
        data[index + 1] = clamp(128 + normalY * softBend * 55 + cornerGlow * 9, 0, 255);
        data[index + 2] = 128;
        data[index + 3] = 255;
      }
    }

    context.putImageData(imageData, 0, 0);
    return canvas.toDataURL();
  };

  const initLiquidGlassNav = (header: HTMLElement) => {
    const glassLayer = header.querySelector<HTMLElement>('[data-liquid-glass-layer]');
    if (!glassLayer || liquidGlassNavCleanups.has(header)) {
      return;
    }

    const supportsBackdropFilter =
      typeof CSS !== 'undefined' &&
      (CSS.supports('backdrop-filter', 'blur(1px)') ||
        CSS.supports('-webkit-backdrop-filter', 'blur(1px)'));

    if (!supportsBackdropFilter) {
      header.dataset.liquidGlassFallback = 'true';
      return;
    }

    const filterId = `nav-liquid-glass-${Math.random().toString(36).slice(2)}`;
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('aria-hidden', 'true');
    svg.setAttribute('focusable', 'false');
    svg.style.cssText = 'position:fixed;width:0;height:0;overflow:hidden;pointer-events:none;';

    const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
    const filter = document.createElementNS('http://www.w3.org/2000/svg', 'filter');
    filter.setAttribute('id', filterId);
    filter.setAttribute('filterUnits', 'userSpaceOnUse');
    filter.setAttribute('color-interpolation-filters', 'sRGB');

    const feImage = document.createElementNS('http://www.w3.org/2000/svg', 'feImage');
    feImage.setAttribute('result', 'glass-map');
    feImage.setAttribute('preserveAspectRatio', 'none');

    const feDisplacementMap = document.createElementNS(
      'http://www.w3.org/2000/svg',
      'feDisplacementMap',
    );
    feDisplacementMap.setAttribute('in', 'SourceGraphic');
    feDisplacementMap.setAttribute('in2', 'glass-map');
    feDisplacementMap.setAttribute('xChannelSelector', 'R');
    feDisplacementMap.setAttribute('yChannelSelector', 'G');

    filter.append(feImage, feDisplacementMap);
    defs.append(filter);
    svg.append(defs);
    document.body.append(svg);

    let frame = 0;
    const mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

    const updateFilter = () => {
      frame = 0;
      const rect = header.getBoundingClientRect();
      const width = Math.max(1, Math.round(rect.width));
      const height = Math.max(1, Math.round(rect.height));
      const radius = parseFloat(window.getComputedStyle(header).borderRadius) || 22;
      const reduceMotion = mediaQuery.matches;
      const map = createLiquidGlassMap(width, height, radius);

      filter.setAttribute('x', '0');
      filter.setAttribute('y', '0');
      filter.setAttribute('width', String(width));
      filter.setAttribute('height', String(height));
      feImage.setAttribute('width', String(width));
      feImage.setAttribute('height', String(height));
      feDisplacementMap.setAttribute(
        'scale',
        reduceMotion ? '0' : String(clamp(width / 58, 9, 16)),
      );

      if (map) {
        feImage.setAttribute('href', map);
      }

      const glassFilter = reduceMotion
        ? 'blur(16px) saturate(1.18)'
        : `url(#${filterId}) blur(14px) saturate(1.28) contrast(1.04)`;
      glassLayer.style.backdropFilter = glassFilter;
      glassLayer.style.webkitBackdropFilter = glassFilter;
      header.dataset.liquidGlassReady = 'true';
    };

    const requestUpdate = () => {
      if (frame) {
        return;
      }

      frame = window.requestAnimationFrame(updateFilter);
    };

    const resizeObserver = new ResizeObserver(requestUpdate);
    resizeObserver.observe(header);
    mediaQuery.addEventListener('change', requestUpdate);

    const onPointerMove = (event: PointerEvent) => {
      if (mediaQuery.matches) {
        return;
      }

      const rect = header.getBoundingClientRect();
      header.style.setProperty('--glass-pointer-x', `${event.clientX - rect.left}px`);
      header.style.setProperty('--glass-pointer-y', `${event.clientY - rect.top}px`);
    };

    const onPointerLeave = () => {
      header.style.removeProperty('--glass-pointer-x');
      header.style.removeProperty('--glass-pointer-y');
    };

    header.addEventListener('pointermove', onPointerMove, { passive: true });
    header.addEventListener('pointerleave', onPointerLeave);
    requestUpdate();

    liquidGlassNavCleanups.set(header, () => {
      if (frame) {
        window.cancelAnimationFrame(frame);
      }

      resizeObserver.disconnect();
      mediaQuery.removeEventListener('change', requestUpdate);
      header.removeEventListener('pointermove', onPointerMove);
      header.removeEventListener('pointerleave', onPointerLeave);
      svg.remove();
      glassLayer.style.backdropFilter = '';
      glassLayer.style.webkitBackdropFilter = '';
      delete header.dataset.liquidGlassReady;
    });
  };

  const initMobileTopNav = () => {
    for (const header of document.querySelectorAll<HTMLElement>('.blog-top-nav')) {
      initLiquidGlassNav(header);

      const toggle = header.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
      const menu = header.querySelector<HTMLElement>('[data-mobile-menu]');
      const tocTrigger = header.querySelector<HTMLButtonElement>('[data-mobile-toc-trigger]');
      const tocMenu = header.querySelector<HTMLElement>('[data-nav-toc-menu]');

      if (!header.dataset.scrollHideReady) {
        header.dataset.scrollHideReady = 'true';

        const topRevealOffset = 24;
        const hideAfterOffset = 96;
        const scrollIntentDelta = 8;
        let lastScrollY = window.scrollY;
        let scrollFrame = 0;

        const setNavHidden = (hidden: boolean) => {
          header.dataset.navHidden = hidden ? 'true' : 'false';
          header.toggleAttribute('inert', hidden);
          header.toggleAttribute('aria-hidden', hidden);
        };

        const shouldKeepVisible = () =>
          window.scrollY <= topRevealOffset ||
          header.dataset.mobileMenuOpen === 'true' ||
          header.dataset.mobileTocOpen === 'true' ||
          header.matches(':focus-within');

        const updateNavVisibility = () => {
          scrollFrame = 0;
          const currentScrollY = window.scrollY;
          const scrollDelta = currentScrollY - lastScrollY;

          if (shouldKeepVisible()) {
            setNavHidden(false);
            lastScrollY = currentScrollY;
            return;
          }

          if (Math.abs(scrollDelta) < scrollIntentDelta) {
            return;
          }

          setNavHidden(scrollDelta > 0 && currentScrollY > hideAfterOffset);
          lastScrollY = currentScrollY;
        };

        window.addEventListener(
          'scroll',
          () => {
            if (scrollFrame) {
              return;
            }

            scrollFrame = window.requestAnimationFrame(updateNavVisibility);
          },
          { passive: true },
        );

        window.addEventListener('resize', () => {
          if (window.scrollY <= topRevealOffset) {
            setNavHidden(false);
          }
        });

        setNavHidden(false);
      }

      if (toggle && menu && !header.dataset.mobileMenuReady) {
        header.dataset.mobileMenuReady = 'true';

        const setMenuOpen = (open: boolean) => {
          header.dataset.mobileMenuOpen = open ? 'true' : 'false';
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute(
            'aria-label',
            open ? 'Close navigation menu' : 'Open navigation menu',
          );
        };
        const setTocOpen = (open: boolean) => {
          if (!tocTrigger || !tocMenu) {
            return;
          }

          header.dataset.mobileTocOpen = open ? 'true' : 'false';
          tocTrigger.setAttribute('aria-expanded', String(open));
          tocTrigger.setAttribute(
            'aria-label',
            open ? 'Close table of contents' : 'Open table of contents',
          );
        };

        toggle.addEventListener('click', () => {
          const nextOpen = header.dataset.mobileMenuOpen !== 'true';
          setMenuOpen(nextOpen);
          header.dataset.navHidden = 'false';
          if (nextOpen) {
            setTocOpen(false);
          }
        });

        menu.addEventListener('click', (event) => {
          if ((event.target as Element).closest?.('[data-mobile-menu-link]')) {
            setMenuOpen(false);
          }
        });

        tocTrigger?.addEventListener('click', () => {
          const nextOpen = header.dataset.mobileTocOpen !== 'true';
          setTocOpen(nextOpen);
          header.dataset.navHidden = 'false';
          if (nextOpen) {
            setMenuOpen(false);
          }
        });

        tocMenu?.addEventListener('click', (event) => {
          if ((event.target as Element).closest?.('[data-nav-toc-link]')) {
            setTocOpen(false);
          }
        });

        document.addEventListener('click', (event) => {
          if (!header.contains(event.target as Node)) {
            setMenuOpen(false);
            setTocOpen(false);
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            setMenuOpen(false);
            setTocOpen(false);
          }
        });
      }
    }
  };

  initMobileTopNav();
  document.addEventListener('astro:page-load', initMobileTopNav);
</script>

<style>
  .blog-top-nav {
    --glass-pointer-x: 50%;
    --glass-pointer-y: 50%;

    position: fixed;
    top: 18px;
    right: 0;
    left: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
    width: min(calc(100% - 32px), 900px);
    min-height: 56px;
    padding: 10px 14px 10px 18px;
    margin: 0 auto;
    border: 0;
    border-radius: 20px;
    background: transparent;
    opacity: 1;
    isolation: isolate;
    transform: translateY(0);
    transition:
      opacity 180ms ease,
      transform 220ms ease;
    will-change: transform;
  }

  .brand,
  .nav-links,
  .nav-actions,
  .mobile-menu-toggle {
    position: relative;
    z-index: 1;
  }

  .nav-liquid-glass {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--paper-line-strong) 72%, rgba(255, 255, 255, 0.52));
    border-radius: inherit;
    background:
      radial-gradient(
        circle at var(--glass-pointer-x) var(--glass-pointer-y),
        rgba(255, 255, 255, 0.38),
        transparent 34%
      ),
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.46),
        rgba(var(--paper-surface-rgb), 0.48) 48%,
        rgba(255, 255, 255, 0.22)
      );
    box-shadow:
      0 18px 48px rgba(31, 35, 40, 0.1),
      0 3px 10px rgba(31, 35, 40, 0.045),
      inset 0 1px 0 rgba(255, 255, 255, 0.86),
      inset 0 -18px 30px rgba(102, 125, 109, 0.08);
    backdrop-filter: blur(16px) saturate(1.18);
    -webkit-backdrop-filter: blur(16px) saturate(1.18);
    pointer-events: none;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 220ms ease;
  }

  .nav-liquid-glass::before,
  .nav-liquid-glass::after {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    content: '';
    pointer-events: none;
  }

  .nav-liquid-glass::before {
    background:
      linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.48) 48%, transparent 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.46), transparent 44%);
    opacity: 0.42;
    mix-blend-mode: screen;
  }

  .nav-liquid-glass::after {
    inset: 1px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.18),
      inset 10px 0 26px rgba(255, 255, 255, 0.16),
      inset -12px -16px 30px rgba(102, 125, 109, 0.08);
  }

  :global(:root[data-theme='dark']) .nav-liquid-glass {
    border-color: color-mix(in srgb, var(--paper-line-strong) 80%, rgba(255, 255, 255, 0.18));
    background:
      radial-gradient(
        circle at var(--glass-pointer-x) var(--glass-pointer-y),
        rgba(255, 255, 255, 0.13),
        transparent 36%
      ),
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.11),
        rgba(var(--paper-surface-rgb), 0.56) 48%,
        rgba(255, 255, 255, 0.06)
      );
    box-shadow:
      0 18px 48px rgba(0, 0, 0, 0.28),
      0 3px 10px rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      inset 0 -18px 30px rgba(168, 186, 169, 0.07);
  }

  :global(:root[data-theme='dark']) .nav-liquid-glass::before {
    opacity: 0.18;
  }

  .blog-top-nav[data-nav-hidden='true'] {
    opacity: 0;
    pointer-events: none;
    transform: translateY(calc(-100% - 24px));
  }

  .mobile-menu-toggle,
  .mobile-menu-panel,
  .mobile-toc-panel {
    display: none;
  }

  .brand,
  a.nav-link,
  a.mobile-menu-link,
  .mobile-toc-panel a {
    color: var(--paper-ink);
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-weight: 700;
  }

  .brand-mark {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--paper-accent);
    box-shadow: none;
  }

  .nav-links {
    display: flex;
    justify-content: center;
    gap: 4px;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    justify-content: center;
    min-width: 74px;
    padding: 9px 12px 12px;
    border: 1px solid transparent;
    border-radius: 14px;
    color: var(--paper-ink-soft);
    font-size: 0.9rem;
    font-weight: 700;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  a.nav-link:hover,
  a.nav-link.active {
    border-color: rgba(255, 255, 255, 0.42);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(var(--paper-surface-rgb), 0.36)),
      var(--paper-control-hover);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.62),
      0 8px 20px rgba(31, 35, 40, 0.06);
    color: var(--paper-accent);
    transform: translateY(-1px);
  }

  .nav-link.active::after {
    position: absolute;
    bottom: 5px;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--paper-accent);
    content: '';
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--paper-accent) 16%, transparent),
      0 0 12px color-mix(in srgb, var(--paper-accent) 34%, transparent);
    transform: translateX(-50%);
  }

  .nav-link-placeholder {
    color: var(--paper-ink-faint);
    cursor: default;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-actions a,
  .nav-actions button:not(.sun-moon-toggle),
  .mobile-menu-toggle {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid color-mix(in srgb, var(--paper-line-strong) 76%, rgba(255, 255, 255, 0.42));
    border-radius: 13px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(var(--paper-surface-rgb), 0.24)),
      var(--paper-control);
    color: var(--paper-ink);
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.54),
      0 4px 14px rgba(31, 35, 40, 0.045);
    backdrop-filter: blur(10px) saturate(1.12);
    -webkit-backdrop-filter: blur(10px) saturate(1.12);
    transition:
      background 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .mobile-menu-toggle,
  .nav-actions .toc-action {
    display: none;
  }

  .nav-actions a:hover,
  .nav-actions button:not(.sun-moon-toggle):hover,
  .mobile-menu-toggle:hover {
    border-color: color-mix(in srgb, var(--paper-accent) 28%, rgba(255, 255, 255, 0.54));
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.46), rgba(var(--paper-surface-rgb), 0.3)),
      var(--paper-control-hover);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.68),
      0 9px 22px rgba(31, 35, 40, 0.07);
    color: var(--paper-accent);
