---
import Icon from '../Icon.astro';

interface Profile {
  name: string;
  handle: string;
  role: string;
  company: string;
  location: string;
  email: string;
  website: string;
  github: string;
  meta: string;
  avatar: string;
}
const { profile } = Astro.props as { profile: Profile };
---

<article class="profile-card">
  <div class="avatar-wrap">
    <img
      src={profile.avatar}
      alt={`${profile.name} GitHub avatar`}
      width="176"
      height="176"
      loading="eager"
    />
  </div>

  <div class="profile-heading">
    <h1>{profile.name}</h1>
    <span><Icon name="sparkle" /> {profile.role}</span>
    <p class="profile-meta">{profile.company}</p>
    <p class="profile-meta">{profile.location}</p>
    <div class="profile-links">
      <a href={`mailto:${profile.email}`}>Connect me!</a>
    </div>
  </div>
</article>

<style>
  .profile-card {
    display: grid;
    justify-items: end;
    min-height: 420px;
    width: 100%;
    padding: 20px 0;
    text-align: right;
    overflow: hidden;
  }

  .avatar-wrap {
    position: relative;
    width: 176px;
    height: 176px;
    margin: 0 0 18px auto;
    padding: 0;
    border-radius: 50%;
    background: transparent;
    box-shadow: none;
  }

  .avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }
  .profile-meta {
    margin: 6px 0 0;
    color: var(--paper-ink-soft);
    font-size: 0.84rem;
  }

  .profile-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 14px;
  }

  .profile-links a {
    color: var(--paper-accent);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
  }

  .profile-links a:hover {
    text-decoration: underline;
  }
  .profile-heading h1 {
    margin: 0;
    color: var(--paper-ink);
    font-size: 1.42rem;
    letter-spacing: 0;
  }

  .profile-heading p {
    margin: 4px 0 14px;
    color: var(--paper-ink-soft);
    font-size: 0.94rem;
  }
  .profile-meta {
    margin: 6px 0 0;
    color: var(--paper-ink-soft);
    font-size: 0.84rem;
  }
  .profile-heading span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    justify-content: flex-end;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--paper-ink);
    font-size: 0.82rem;
  }

  .profile-heading svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
    color: var(--paper-accent);
  }

  @media (max-width: 820px) {
    .profile-card {
      justify-items: center;
      min-height: auto;
      padding: 4px 0 0;
      text-align: center;
    }

    .avatar-wrap {
      margin-right: auto;
      margin-left: auto;
    }

    .profile-heading span {
      justify-content: center;
    }
  }
</style>
